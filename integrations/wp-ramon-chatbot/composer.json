{
    "name": "ramon/wp-chatbot",
    "description": "RAMon AI chatbot integration for WordPress/WooCommerce",
    "type": "wordpress-plugin",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Ramon\\Chatbot\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ramon\\Chatbot\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "phpstan/phpstan": "^1.12"
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "test": "phpunit",
        "post-install-cmd": "bash copy_assets.sh",
        "post-update-cmd": "bash copy_assets.sh"
    }
}
