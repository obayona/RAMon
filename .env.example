# Database settings (used by docker-compose and application)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ramon
DB_USER=ramon
DB_PASSWORD='' # Use a strong password (generate: openssl rand -base64 24)

# API Keys
OPENAI_API_KEY='' # API key for the OpenAI chat model
TAVILY_API_KEY='' # API key for web search results

# Optional overrides
OPENAI_MODEL='' # Default: gpt-4o-mini
OPENAI_TEMPERATURE='' # Default: 0

# Auth settings
APP_KEY='' # Key for JWT auth (generate: openssl rand -base64 32)
GUEST_USER='guest' # Guest user for basic auth
GUEST_PASSWORD='guest' # Guest password for basic auth

# Production settings (required for docker-compose.prod.yml)
DOMAIN='' # Your domain (e.g., api.example.com)
CERTBOT_EMAIL='' # Email for Let's Encrypt notifications
