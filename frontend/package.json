{
  "name": "ramon-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "RAMon AI chat widget",
  "scripts": {
    "dev": "node server.cjs --dev",
    "build": "tsc -b && vite build --config vite.widget.config.ts && cp src/loader.js dist-widget/ramon.js && cp fonts/*.woff2 dist-widget/",
    "start": "node server.cjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@tailwindcss/vite": "^4.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "framer-motion": "^12.42.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
